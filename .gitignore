# ------------------------------------------------------------
# Fluxer Bot + Web Dashboard (root workspace ignore rules)
# ------------------------------------------------------------

# Python cache and build artifacts
.vscode
__pycache__/
*.py[cod]
*$py.class
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# Python virtual environments
.venv/
venv/
env/
ENV/

# Local environment files (examples remain tracked)
.env
.env.*
!.env.example
!.env.*.example
web_dashboard_ts/.env
web_dashboard_ts/.env.*

# Sensitive local token/key files
bot_js/token.txt
bot_js/google.txt

# JavaScript and Rust build artifacts
node_modules/
bot_js/node_modules/
bot_js/raid_ml_sidecar/target/
bot_js/.npm/
bot_js/npm-debug.log*
bot_js/yarn-debug.log*
bot_js/yarn-error.log*
bot_js/pnpm-debug.log*

# Runtime SQLite files
bot_js/data/warnings.db
bot_js/data/warnings.db-shm
bot_js/data/warnings.db-wal
bot_js/data/*.db
bot_js/data/words.json
*.db-shm
*.db-wal

# Logs and transient runtime output
*.log
*.out
*.err
*.pid

# OS noise
.DS_Store
Thumbs.db
Desktop.ini

# Nested dashboard git backup (created when converting nested repo to normal folder)
web_dashboard_ts/.git_nested_backup_*/